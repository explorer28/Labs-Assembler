.486
.model flat, stdcall
option casemap :none

include windows.inc
include kernel32.inc
include masm32.inc
includelib kernel32.lib
includelib masm32.lib

.data
    msgA    db "Введите a: ", 0
    msgB    db "Введите b: ", 0
    msgZ    db "Результат z = ", 0
    bufA    db 100 dup(?)
    bufB    db 100 dup(?)
    bufZ    db 100 dup(?)

.data?
    hIn dd ? | hOut dd ? | written dd ?
    a   dq ?
    b   dq ?
    z   dq ?

.code
entryPoint:
    push STD_INPUT_HANDLE | call GetStdHandle | mov hIn, eax
    push STD_OUTPUT_HANDLE | call GetStdHandle | mov hOut, eax

    push offset msgA | call PrintStr
    push NULL | push offset written | push 100 | push offset bufA | push hIn | call ReadConsole
    mov edx, offset bufA | mov eax, written | mov byte ptr [edx+eax-2], 0
    invoke StrToFloat, offset bufA, offset a

    push offset msgB | call PrintStr
    push NULL | push offset written | push 100 | push offset bufB | push hIn | call ReadConsole
    mov edx, offset bufB | mov eax, written | mov byte ptr [edx+eax-2], 0
    invoke StrToFloat, offset bufB, offset b

    finit
    fld a       ; ST(0) = a
    fld b       ; ST(0) = b, ST(1) = a
    
    fld a       ; ST(0) = a, ST(1) = b, ST(2) = a
    fadd ST(0), ST(1) ; ST(0) = a + b
    fmul ST(0), ST(0) ; ST(0) = (a + b)^2

    fsubr ST(2), ST(1)
    
    fdiv ST(0), ST(2)
    fstp z

    push offset bufZ
    push dword ptr z + 4
    push dword ptr z
    call FloatToStr

    push offset msgZ | call PrintStr
    push offset bufZ | call PrintStr

    push NULL | push offset written | push 1 | push offset bufA | push hIn | call ReadConsole
    push 0 | call ExitProcess
end entryPoint
